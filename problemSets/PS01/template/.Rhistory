KS_test <- function(data) {
ECDF <- ecdf(data) #create the fuction
empiricalCDF <- ECDF(data) #create imperical distribution using the function
# generate test statistic
D <- max(abs(empiricalCDF - pnorm(data)))
bigsum <- 0 #setup empty int
#calculate that big sum part of the equation
for (i in 1:length(data)) {
result = exp(-((2*i-1)^2 * pi^2) / (8*D^2))
bigsum <-bigsum + result
}
# multiply by the part outside the sum
final = (sqrt(2*pi)/D)*bigsum
print(final)
}
