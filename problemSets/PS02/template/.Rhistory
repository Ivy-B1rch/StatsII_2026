# load data
load(url("https://github.com/ASDS-TCD/StatsII_2026/blob/main/datasets/climateSupport.RData?raw=true"))
View(climateSupport)
climateSupport <- climateSupport |>
mutate(choice = as.factor(choice))
lapply(c("tidyverse"),  pkgTest)
climateSupport <- climateSupport |>
mutate(choice = as.factor(choice))
summary(climateSupport$choice)
logit_base <- glm(choice ~ countries + sanctions, data = climateSupport, family = binomial(link="logit"))
logit_base
summary(logit_base)
View(climateSupport)
